# ============================================================================
# Company Brain — configuration. Copy to .env and edit. NEVER commit .env.
# ============================================================================

# --- Authentication (REQUIRED) ---------------------------------------------
# Comma-separated "key:agent" pairs. Each AI/client gets its own key so the
# brain knows who wrote/searched what. Generate strong keys with:
#     python scripts/gen_key.py
# Example:
#   BRAIN_API_KEYS=Kf3...long-random:claude-code,Qz9...long-random:cursor
BRAIN_API_KEYS=

# --- Embeddings (local, CPU, no data leaves the box) -----------------------
# Default is multilingual (Sinhala + English + code).
#   Lighter/faster : sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
#   Best quality   : intfloat/multilingual-e5-large   (1024-dim, heavier on CPU)
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2

# --- Vector store ----------------------------------------------------------
# With docker-compose this is set automatically to the private qdrant service.
# Leave blank to use an embedded on-disk Qdrant (no separate service).
# QDRANT_URL=http://qdrant:6333
# QDRANT_API_KEY=
QDRANT_COLLECTION=company_brain

# --- Storage ---------------------------------------------------------------
BRAIN_DATA_DIR=./data

# --- Behaviour -------------------------------------------------------------
# Save every search query into the brain as an "activity" memory.
LOG_SEARCHES=true
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# --- API server ------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
RATE_LIMIT=120/minute
MAX_BODY_BYTES=2000000
# Comma-separated allowed browser origins (leave blank to allow none).
CORS_ORIGINS=

# --- Optional HTTPS overlay (docker-compose.tls.yml) -----------------------
# BRAIN_DOMAIN=brain.example.com
# ACME_EMAIL=you@example.com
